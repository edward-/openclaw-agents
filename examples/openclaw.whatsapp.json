{
    "agents": {
        "list": [
            {
                "id": "main",
                "name": "🐾 OpenClaw",
                "workspace": "~/.openclaw/workspace-main",
                "model": "zai/glm-5",
                "default": true,
                "identity": {
                    "name": "🐾 OpenClaw"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@openclaw",
                        "openclaw"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "planner",
                "name": "🧠 Planner",
                "workspace": "~/.openclaw/workspace-planner",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🧠 Planner"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@planner",
                        "planner"
                    ],
                    "historyLimit": 50
                }
            }
        ],
        "defaults": {
            "sandbox": {
                "mode": "non-main",
                "scope": "session",
                "workspaceAccess": "none"
            }
        }
    },
    "bindings": [
        {
            "agentId": "main",
            "match": {
                "channel": "whatsapp",
                "peer": {
                    "kind": "group",
                    "id": "YOUR_GROUP_ID@g.us"
                }
            }
        },
        {
            "agentId": "planner",
            "match": {
                "channel": "whatsapp",
                "peer": {
                    "kind": "group",
                    "id": "YOUR_GROUP_ID@g.us"
                }
            }
        }
    ],
    "channels": {
        "whatsapp": {
            "groupPolicy": "allowlist",
            "groupAllowFrom": [
                "+15551234567"
            ],
            "groups": {
                "YOUR_GROUP_ID@g.us": {
                    "requireMention": true
                }
            },
            "dmPolicy": "pairing"
        }
    },
    "messages": {
        "groupChat": {
            "historyLimit": 50
        }
    }
}
