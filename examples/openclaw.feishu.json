{
    "agents": {
        "list": [
            {
                "id": "main",
                "name": "🐾 OpenClaw",
                "workspace": "~/.openclaw/workspace-main",
                "model": "zai/glm-5",
                "default": true,
                "identity": {
                    "name": "🐾 OpenClaw"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@openclaw",
                        "openclaw",
                        "@OpenClaw"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "planner",
                "name": "🧠 Planner",
                "workspace": "~/.openclaw/workspace-planner",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🧠 Planner"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@planner",
                        "planner",
                        "@Planner"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "ideator",
                "name": "💡 Ideator",
                "workspace": "~/.openclaw/workspace-ideator",
                "model": "zai/glm-5",
                "identity": {
                    "name": "💡 Ideator"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@ideator",
                        "ideator",
                        "@Ideator"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "critic",
                "name": "🎯 Critic",
                "workspace": "~/.openclaw/workspace-critic",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🎯 Critic"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@critic",
                        "critic",
                        "@Critic"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "surveyor",
                "name": "📚 Surveyor",
                "workspace": "~/.openclaw/workspace-surveyor",
                "model": "zai/glm-5",
                "identity": {
                    "name": "📚 Surveyor"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@surveyor",
                        "surveyor",
                        "@Surveyor"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "coder",
                "name": "💻 Coder",
                "workspace": "~/.openclaw/workspace-coder",
                "model": "zai/glm-5",
                "identity": {
                    "name": "💻 Coder"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@coder",
                        "coder",
                        "@Coder"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "writer",
                "name": "✍️ Writer",
                "workspace": "~/.openclaw/workspace-writer",
                "model": "zai/glm-5",
                "identity": {
                    "name": "✍️ Writer"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@writer",
                        "writer",
                        "@Writer"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "reviewer",
                "name": "🔍 Reviewer",
                "workspace": "~/.openclaw/workspace-reviewer",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🔍 Reviewer"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@reviewer",
                        "reviewer",
                        "@Reviewer"
                    ],
                    "historyLimit": 50
                }
            },
            {
                "id": "scout",
                "name": "📰 Scout",
                "workspace": "~/.openclaw/workspace-scout",
                "model": "zai/glm-5",
                "identity": {
                    "name": "📰 Scout"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@scout",
                        "scout",
                        "@Scout"
                    ],
                    "historyLimit": 50
                }
            }
        ],
        "defaults": {
            "sandbox": {
                "mode": "non-main",
                "scope": "session",
                "workspaceAccess": "none"
            }
        }
    },
    "bindings": [
        {
            "agentId": "main",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "planner",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "ideator",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "critic",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "surveyor",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "coder",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "writer",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "reviewer",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        },
        {
            "agentId": "scout",
            "match": {
                "channel": "feishu",
                "peer": {
                    "kind": "group",
                    "id": "oc_YOUR_GROUP_ID_HERE"
                }
            }
        }
    ],
    "channels": {
        "feishu": {
            "groupPolicy": "allowlist",
            "groupAllowFrom": [
                "oc_YOUR_GROUP_ID_HERE"
            ],
            "groups": {
                "oc_YOUR_GROUP_ID_HERE": {
                    "requireMention": true
                }
            },
            "streaming": true,
            "blockStreaming": true
        }
    },
    "messages": {
        "groupChat": {
            "historyLimit": 50
        }
    }
}
